-- Rocket stabilizer using CC: Redstone Link Bridge
-- Uses sendLinkSignal(freq1, freq2, strength)
-- Gyro: gimbal_sensor from Create: Avionics

local FREQ1 = "powergrid:generator_induction_rotor"

-- Assign unique channel numbers for each engine input
local channels = {
    front = { up = 'minecraft:black_dye", down = "minecraft:cherry_sapling", left = "minecraft:cobblestone", right = "powergrid:wire_connector", thrust = "minecraft:blue_dye" },
    back  = { up = "minecraft:light_gray_dye", down = "create:iron_sheet", left = "create:experience_block", right = "create_connected:parallel_gearbox", thrust = "minecraft:blue_dye" },
    left  = { up = "minecraft:white_dye", down = 'create_connected:fluid_vessel", left = "minecraft:bread", right = "create:large_cogwheel", thrust = "minecraft:blue_dye" },
    right = { up = "minecraft:bone_meal", down = "minecraft:stick", left = "minecraft:dirt", right = "create_connected:parallel_gearbox", thrust = "minecraft:blue_dye" }
}

-- PID coefficients (tune later)
local Kp = 0.6
local Ki = 0.02
local Kd = 0.15

local TARGET_PITCH = 0
local TARGET_ROLL = 0
local THRUST = 5          -- base thrust for side engines
local MAIN_THRUST = 15    -- central engine power
local DT = 0.05           -- control loop period (seconds)
local MAX_ANGLE = 30      -- max nozzle deflection (degrees)

-- Find peripherals
local gyro = peripheral.find("gimbal_sensor")
if not gyro then error("Gyro not found!") end
print("Gyro found.")

local linkBridge = peripheral.find("redstone_link_bridge")
if not linkBridge then error("Redstone Link Bridge not found!") end
print("Redstone Link Bridge found.")

-- Helper functions
local function send_signal(channel, value)
    if not channel then return end
    local signal = math.floor(math.max(0, math.min(15, value)))
    linkBridge.sendLinkSignal(FREQ1, channel, signal)
end

local function clamp(val, min_val, max_val)
    return math.max(min_val, math.min(max_val, val))
end

-- Test function for a single engine
local function test_engine(name, dir_channel, thrust_channel)
    print("Testing: " .. name)
    send_signal(thrust_channel, 5)   -- small thrust
    sleep(1)
    send_signal(dir_channel, 15)     -- max deflection
    sleep(2)
    send_signal(dir_channel, 0)      -- center
    sleep(1)
    send_signal(thrust_channel, 0)   -- off
    print("---")
end

-- Run all tests
local function run_tests()
    print("===== ENGINE TESTS START =====")
    print("Each engine will: turn on, deflect, return, turn off.")
    sleep(1)
    test_engine("Front (up)", channels.front.up, channels.front.thrust)
    test_engine("Back (down)", channels.back.down, channels.back.thrust)
    test_engine("Left (left)", channels.left.left, channels.left.thrust)
    test_engine("Right (right)", channels.right.right, channels.right.thrust)
    print("===== TESTS COMPLETE =====")
end

-- Ask user whether to run tests (with timeout)
print("Press any key to run engine tests, or wait 5 seconds to skip.")
local event = os.pullEvent("key")
if event then
    run_tests()
else
    print("Skipping tests.")
end

-- Set base thrust for side engines
send_signal(channels.front.thrust, THRUST)
send_signal(channels.back.thrust, THRUST)
send_signal(channels.left.thrust, THRUST)
send_signal(channels.right.thrust, THRUST)

-- Start central engine (via redstone on "bottom")
redstone.setAnalogOutput("bottom", MAIN_THRUST)
print("Central engine ON at power " .. MAIN_THRUST)

print("Stabilizer running. Press Ctrl+T to stop.")

-- PID state variables
local integral_p = 0
local integral_r = 0
local prev_error_p = 0
local prev_error_r = 0

-- Main control loop
while true do
    -- Get angles from gyro (returns table {pitch, roll})
    local angles = gyro.getAngles()
    local pitch = angles[1] or 0
    local roll = angles[2] or 0

    local error_p = TARGET_PITCH - pitch
    local error_r = TARGET_ROLL - roll

    -- Pitch PID
    integral_p = integral_p + error_p * DT
    integral_p = clamp(integral_p, -50, 50)
    local derivative_p = (error_p - prev_error_p) / DT
    local control_p = Kp * error_p + Ki * integral_p + Kd * derivative_p
    prev_error_p = error_p

    -- Roll PID
    integral_r = integral_r + error_r * DT
    integral_r = clamp(integral_r, -50, 50)
    local derivative_r = (error_r - prev_error_r) / DT
    local control_r = Kp * error_r + Ki * integral_r + Kd * derivative_r
    prev_error_r = error_r

    -- Clamp control outputs
    control_p = clamp(control_p, -MAX_ANGLE, MAX_ANGLE)
    control_r = clamp(control_r, -MAX_ANGLE, MAX_ANGLE)

    -- Convert angle to signal (0-15)
    local function angle_to_signal(angle)
        return (angle / MAX_ANGLE) * 15
    end

    local front_signal = angle_to_signal(control_p)
    local back_signal = angle_to_signal(-control_p)
    local left_signal = angle_to_signal(control_r)
    local right_signal = angle_to_signal(-control_r)

    -- Send to engines
    send_signal(channels.front.up, front_signal)
    send_signal(channels.front.down, 0)

    send_signal(channels.back.down, back_signal)
    send_signal(channels.back.up, 0)

    send_signal(channels.left.left, left_signal)
    send_signal(channels.left.right, 0)

    send_signal(channels.right.right, right_signal)
    send_signal(channels.right.left, 0)

    -- Optional debug output (uncomment if needed)
    -- print(string.format("P: %6.2f  R: %6.2f  cP: %6.2f  cR: %6.2f",
    --       pitch, roll, control_p, control_r))

    sleep(DT)
end
